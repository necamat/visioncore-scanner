{
  "ProcessingOptions": {
    "InputFolder": "./input",
    "OutputFolder": "./output",
    "OutputFileName": "QuizResult.xlsx"
  },
  "ScanSource": {
    "RoundFolderPrefix": "R",
    "SearchPatterns": [ "*.pdf" ]
  },
  "DigitRecognitionOptions": {
    "DarkPixelThreshold": 160,
    "TemplateWidth": 48,
    "TemplateHeight": 72,
    "MinimumInkRatio": 0.01,
    "MinimumDigitWidth": 4,
    "TemplateMatchThreshold": 0.50
  },
  "ConfidenceEvaluationOptions": {
    "MinimumAcceptedConfidence": 0.80,
    "MinimumReviewConfidence": 0.65
  },
  "PdfRegions": {
    "_comment": "Pixel coordinates for A4 @ 200 DPI (1654 x 2338 px). Measured against the printed form; re-measure if the layout changes.",
    "Dpi": 200,
    "TeamId": {
      "_comment": "Team-id box — upper-right",
      "X": 1330,
      "Y": 200,
      "Width": 110,
      "Height": 120
    },
    "TeamIdDigit1": {
      "X": 1338,
      "Y": 214,
      "Width": 46,
      "Height": 92
    },
    "TeamIdDigit2": {
      "X": 1392,
      "Y": 214,
      "Width": 46,
      "Height": 92
    },
    "Score": {
      "_comment": "Score container box — lower-center",
      "X": 1090,
      "Y": 1980,
      "Width": 295,
      "Height": 120
    },
    "ScoreDigit1": {
      "X": 1108,
      "Y": 1999,
      "Width": 78,
      "Height": 82
    },
    "ScoreDigit2": {
      "X": 1198,
      "Y": 1999,
      "Width": 78,
      "Height": 82
    },
    "ScoreDigit3": {
      "X": 1288,
      "Y": 1999,
      "Width": 78,
      "Height": 82
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/visioncore-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
